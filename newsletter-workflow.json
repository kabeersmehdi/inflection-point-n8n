    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "email-html",
              "name": "full_email_html",
              "value": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"color-scheme\" content=\"dark\">\n  <title>Inflection Point</title>\n</head>\n<body style=\"margin:0;padding:0;background-color:#0a0a0a;font-family:'Inter',system-ui,-apple-system,sans-serif;\">\n<div style=\"display:none;max-height:0;overflow:hidden;font-size:1px;line-height:1px;color:#0a0a0a;\">Your weekly AI briefing, built for you. Inflection Point — Week of {{ $now.startOf('week').plus(1, 'days').toFormat('MMMM d, YYYY') }}&#8199;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;&#847;</div>\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#0a0a0a;\">\n  <tr>\n    <td align=\"center\" style=\"padding:40px 16px;\">\n      <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:600px;width:100%;\">\n        <tr>\n          <td style=\"padding-bottom:32px;\">\n            <p style=\"margin:0 0 4px 0;font-size:22px;font-weight:800;color:#6c63ff;letter-spacing:0.18em;text-transform:uppercase;font-family:Inter,system-ui,sans-serif;\">INFLECTION POINT</p>\n            <p style=\"margin:0 0 2px 0;font-size:12px;color:#8a8fa8;letter-spacing:0.05em;font-family:Inter,system-ui,sans-serif;\">AI intelligence, curved to you.</p>\n            <p style=\"margin:0 0 20px 0;font-size:12px;color:#8a8fa8;font-family:Inter,system-ui,sans-serif;\">Week of {{ $now.startOf('week').plus(1, 'days').toFormat('MMMM d, YYYY') }}</p>\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n              <tr><td style=\"border-top:1px solid #1e2030;font-size:0;\">&nbsp;</td></tr>\n            </table>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"background-color:#111318;border-radius:16px;padding:36px 32px;border:1px solid #1e2030;\">\n            {{ $json.claude_output }}\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:28px 0 0 0;\">\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n              <tr><td style=\"border-top:1px solid #1e2030;font-size:0;\">&nbsp;</td></tr>\n            </table>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:24px 0 40px 0;text-align:center;\">\n            <p style=\"margin:0 0 4px 0;font-size:11px;font-weight:700;color:#6c63ff;letter-spacing:0.15em;text-transform:uppercase;font-family:Inter,system-ui,sans-serif;\">INFLECTION POINT</p>\n            <p style=\"margin:0 0 12px 0;font-size:11px;color:#8a8fa8;font-family:Inter,system-ui,sans-serif;\">You are at the curve. Stay sharp.</p>\n            <p style=\"margin:0;font-size:11px;color:#8a8fa8;font-family:Inter,system-ui,sans-serif;\"><a href=\"{{ $json.unsubscribe_link || '#' }}\" style=\"color:#8a8fa8;text-decoration:underline;font-family:Inter,system-ui,sans-serif;\">Unsubscribe</a> · You're receiving this because you signed up for Inflection Point.</p>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n</body>\n</html>",
              "type": "string"
            },
