              "id": "check-name",
              "name": "check_name",
              "value": "={{ $json.claude_output.includes($node[\"Set — Build Dynamic Prompt\"].json.user_name) }}",
              "type": "boolean"
            },
            {
              "id": "check-length",
              "name": "check_length",
              "value": "={{ $json.claude_output.length > 800 }}",
              "type": "boolean"
            },
            {
              "id": "check-sections",
              "name": "check_sections",
              "value": "={{ ($json.claude_output.match(/letter-spacing:0\\.12em/g) || []).length >= 2 }}",
              "type": "boolean"
            },
            {
              "id": "check-exclude",
              "name": "check_exclude",
              "value": "={{ (() => { const exclusions = ($node[\"Set — Build Dynamic Prompt\"].json.exclude || '').toLowerCase().split(',').map(s => s.trim()).filter(s => s); if (exclusions.length === 0) return true; const content = $json.claude_output.toLowerCase(); return !exclusions.some(ex => content.includes(ex)); })() }}",
              "type": "boolean"
            },
            {
              "id": "overall-quality",
              "name": "overall_quality",
              "value": "={{ $json.check_name && $json.check_length && $json.check_sections && $json.check_exclude }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
